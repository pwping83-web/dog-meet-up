# ========== 1. Supabase 연결 ==========
# 대시보드: Connect 또는 Settings → API → Project API keys
# 프론트에는 게시 가능한 키만: JWT anon(eyJ…) 또는 sb_publishable_…
# 비밀 키(sb_secret_…)·service_role JWT·DB 비밀번호는 절대 프론트·VITE_*·Git에 넣지 마세요.
# - VITE_ 변수는 브라우저 번들에 포함될 수 있습니다.
# - Edge Functions: 대시보드 → Edge Functions → Secrets 에만 등록 (로컬 .env에 복사 금지 권장)
#   AI 도우미(daeng-ai-assist): GEMINI_API_KEY (Google AI Studio → API 키, AIza…)
# - 로컬 서버 스크립트만: .env.server 등 + .gitignore. 레포 커밋 금지.
VITE_SUPABASE_URL=https://silbyvmcuymjewurkrfn.supabase.co
VITE_SUPABASE_ANON_KEY=

# (선택) 로컬 CLI/psql/ORM 전용 — Vite에 VITE_ 접두사 붙이지 말 것
# DATABASE_URL=postgresql://postgres:비밀번호@db.silbyvmcuymjewurkrfn.supabase.co:5432/postgres

# 사이트 URL (OAuth 리다이렉트). 비우면 앱이 window.location.origin 사용 (로컬에서도 동작)
# 사이트 기준 URL(선택). 카카오 OAuth redirect_to는 **접속 중인 브라우저 origin**을 씁니다.
# www / 비-www 를 섞어 쓰면 둘 다 Supabase Redirect URLs에 등록하세요.
#   VITE_SITE_URL=http://localhost:5173
# Supabase → Authentication → URL Configuration:
#   Site URL: http://localhost:5173
#   Redirect URLs: http://localhost:5173/**  (카카오 콜백 후 /explore 로 돌아오므로 /** 권장)
# 카카오 → 플랫폼 Web: http://localhost:5173
VITE_SITE_URL=

# ========== 2. 카카오 디벨로퍼 연결 ==========
# https://developers.kakao.com/ → 내 애플리케이션 → 앱 설정
#
# [지도] 앱 키 → JavaScript 키 (플랫폼 Web 도메인 등록: localhost, 배포 URL)
VITE_KAKAO_MAP_APP_KEY=
#
# [로그인] Supabase가 카카오 OAuth를 처리합니다. 프론트에 카카오 REST 시크릿을 넣지 마세요.
# ① 카카오 콘솔 → 제품 설정 → 카카오 로그인 → Redirect URI 에 추가:
#    https://silbyvmcuymjewurkrfn.supabase.co/auth/v1/callback
# ② Supabase → Authentication → Providers → Kakao → Client ID / Secret (카카오 앱의 REST API 키 등)
# ③ Supabase → Authentication → URL Configuration → Site URL / Redirect URLs 에 실제 웹 주소 등록
# ④ (권장) Supabase Kakao → "Allow users without an email" ON — 아래 기본 scope는 이메일 미요청
# (선택) 비즈 동의 후 이메일까지 쓰려면 예: VITE_KAKAO_AUTH_SCOPES=profile_nickname profile_image account_email
# VITE_KAKAO_AUTH_SCOPES=profile_nickname profile_image

# ========== Google Play (선택) ==========
VITE_PLAY_STORE_URL=

# 앱·PWA 설치 유도 UI (우측 FAB 등). 출시 전에는 비우기, 출시 후 true
# VITE_SHOW_APP_INSTALL=true

# ========== 웹앱(PWA) 원클릭 설치 ==========
# 별도 키 없음. `npm run build` 후 HTTPS로 배포하면 manifest+서비스워커가 포함됩니다.
# 화면 오른쪽 위 "앱 설치" / "앱으로 쓰기" 버튼: Chrome은 원클릭, iOS는 Safari 안내.

# ========== Git + Vercel: 푸시만 하면 배포 (수동 Deploy 불필요) ==========
# Vercel → 프로젝트 → Settings → Git 에서 이 GitHub 저장소를 연결해 두면,
# Production Branch(보통 main)로 push 할 때마다 자동 빌드·배포됩니다. Deploy 버튼을 누를 필요 없습니다.
# (저장소만 가져온 “Import” 프로젝트면 Git 연결이 없어 수동 배포만 될 수 있으니 Git 연동을 확인하세요.)
#
# 로컬에서 스테이징+커밋+푸시 한 번에:
#   npm run git:push -- "커밋 메시지"
# 메시지 생략 시 chore: update. 푸시 후 CI: .github/workflows/ci.yml

# 1. 패키지 모듈 (가장 중요 ⭐️ 토큰 먹는 하마)
node_modules/

# 2. 빌드 결과물 (자동 생성되는 파일들)
dist/
build/
out/
.vercel/

# 3. 정적 자원 (이미지, 비디오 등 AI가 텍스트로 읽을 필요 없는 것들)
public/
assets/
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.webp
*.mp4
*.mp3
*.woff
*.woff2
*.ttf

# 4. 환경 변수 (보안을 위해 AI에게 읽히지 않는 것이 좋음)
.env
.env.*

# 5. 기타 시스템 및 로그 파일
.git/
*.log
package-lock.json